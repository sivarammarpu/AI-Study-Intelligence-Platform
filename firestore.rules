rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Users can only read and write their own profile document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. Users can only read, create, update, and delete their own study materials
    // Assuming collections like 'summaries', 'quizzes', 'flashcards', 'curriculums', 'exams'
    match /{collection}/{docId} {
      allow read, write: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Also allow reading/updating existing docs if they already belong to the user
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
